layout_mode = 2

[node name="FilaVolumen" type="HBoxContainer" parent="Centro/Tarjeta/Columna"]
layout_mode = 2

[node name="Etiqueta" type="Label" parent="Centro/Tarjeta/Columna/FilaVolumen"]
