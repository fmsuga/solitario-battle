[ext_resource type="StyleBox" path="res://assets/estilos/panel_tarjeta.tres" id="3_panel"]
[ext_resource type="StyleBox" path="res://assets/estilos/boton_primario.tres" id="4_primario"]
[ext_resource type="StyleBox" path="res://assets/estilos/boton_primario_hover.tres" id="5_primario_hover"]
[ext_resource type="StyleBox" path="res://assets/estilos/boton_secundario.tres" id="6_secundario"]
[ext_resource type="StyleBox" path="res://assets/estilos/boton_secundario_hover.tres" id="7_secundario_hover"]
