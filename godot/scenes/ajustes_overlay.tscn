[ext_resource type="FontVariation" path="res://assets/fuentes/noto_sans_negrita.tres" id="11_negrita"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_fondo"]
bg_color = Color(0, 0, 0, 0.72)

[node name="AjustesOverlay" type="Control"]
visible = false
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_ajustes")

[node name="Fondo" type="Button" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
focus_mode = 0
theme_override_styles/normal = SubResource("StyleBoxFlat_fondo")
theme_override_styles/hover = SubResource("StyleBoxFlat_fondo")
theme_override_styles/pressed = SubResource("StyleBoxFlat_fondo")
theme_override_styles/focus = SubResource("StyleBoxFlat_fondo")

[node name="Centro" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Tarjeta" type="PanelContainer" parent="Centro"]
custom_minimum_size = Vector2(420, 0)
layout_mode = 2
theme_override_styles/panel = ExtResource("3_panel")

[node name="Columna" type="VBoxContainer" parent="Centro/Tarjeta"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Titulo" type="Label" parent="Centro/Tarjeta/Columna"]
layout_mode = 2
theme_override_colors/font_color = Color(0.96, 0.94, 0.84, 1)
theme_override_colors/font_outline_color = Color(0.96, 0.94, 0.84, 1)
theme_override_constants/outline_size = 6
theme_override_fonts/font = ExtResource("10_titulo")
theme_override_font_sizes/font_size = 42
text = "AJUSTES"
horizontal_alignment = 1

[node name="Separador" type="ColorRect" parent="Centro/Tarjeta/Columna"]
custom_minimum_size = Vector2(64, 3)
layout_mode = 2
size_flags_horizontal = 4
color = Color(0.898, 0.745, 0.447, 0.6)

[node name="EspacioTituloVolumen" type="Control" parent="Centro/Tarjeta/Columna"]
